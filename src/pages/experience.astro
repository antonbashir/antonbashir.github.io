---
import Head from "../layouts/Head.astro";
import Navigation from "../layouts/Navigation.astro";
import "../styles/global.css";
import "../styles/experience.css";
---

<html lang="en">
  <head>
    <Head title="🦊 Anton Bashirov | Experience" />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0"
    />
  </head>
  <body>
    <Navigation page="experience" />
    <div class="flex place-items-center">
      <div class="flex place-items-center flex-1 pt-4 px-4">
        <span
          class="material-symbols-outlined text-3xl drop-shadow-glow text-purple-300"
          >experiment</span
        >
        <p class="text-xl lg:text-3xl font-bold px-4">The path I've taken</p>
      </div>
    </div>
    <div class="divider"></div>
    <div class="container flex flex-row place-items-center">
      <div class="description border-green-200 border-x border-y p-4">
        <p>The begining of my path</p>
      </div>
      <progress class="label" value="100" max="100"></progress>
      <div class="glowing-circle"></div>
    </div>
    <div class="flex place-content-center">
      <div class="imageContainer">
        <img
          class="object-fill h-full w-full max-w-7xl m-16 rounded-3xl foregroundImg"
          src="/experience.jpeg"
        />
        <img
          class="object-fill h-full w-full max-w-7xl m-16 rounded-3xl backgroundImg"
          src="/experience.jpeg"
        />
      </div>
    </div>
  </body>
</html>
