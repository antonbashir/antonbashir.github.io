---
import Head from "../layouts/Head.astro";
import Navigation from "../layouts/Navigation.astro";
---

<html lang="en">
  <head>
    <Head title="🦊 Anton Bashirov | Contact" />
  </head>
  <body>
    <Navigation page="contact" />
    <div class="divider"></div>
    <div class="flex flex-col m-auto max-w-none w-2/3 prose">
      <label class="form-control w-full max-w-none">
        <div class="label">
          <span class="label-text"><h3>What is your name ?</h3></span>
        </div>
        <input
          type="text"
          placeholder="Type here"
          class="input input-bordered input-lg w-full max-w-none"
        />
      </label>

      <label class="form-control w-full max-w-none">
        <div class="label">
          <span class="label-text"><h3>What is your email ?</h3></span>
        </div>
        <input
          type="text"
          placeholder="Type here"
          class="input input-bordered input-lg w-full max-w-none"
        />
      </label>

      <label class="form-control w-full max-w-none">
        <div class="label">
          <span class="label-text"><h3>What is your case ?</h3></span>
        </div>
        <label class="label cursor-pointer">
          <span class="label-text text-lg">Hiring</span>
          <input type="radio" name="case" class="radio" checked />
        </label>
        <label class="label cursor-pointer">
          <span class="label-text text-lg">Chating</span>
          <input type="radio" name="case" class="radio" />
        </label>
        <label class="label cursor-pointer">
          <span class="label-text text-lg">Open-Source projects</span>
          <input type="radio" name="case" class="radio" />
        </label>
        <label class="label cursor-pointer">
          <span class="label-text text-lg">Technical question</span>
          <input type="radio" name="case" class="radio" />
        </label>
        <label class="label cursor-pointer">
          <span class="label-text text-lg">Other</span>
          <input type="radio" name="case" class="radio" />
        </label>
      </label>

      <label class="form-control w-full max-w-none">
        <div class="label">
          <span class="label-text"><h3>Describe your request</h3></span>
        </div>
        <textarea class="textarea textarea-bordered h-24" placeholder=""
        ></textarea>
      </label>

      <button class="btn my-8 btn-wide btn-lg"> Submit</button>
    </div>
  </body>
</html>
