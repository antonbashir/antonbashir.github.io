---
import { getCollection } from "astro:content";
import Navigation from "../../layouts/Navigation.astro";
import Head from "../../layouts/Head.astro";
export async function getStaticPaths() {
  return (await getCollection("blog")).map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}
const { post } = Astro.props;
const { Content } = await post.render();
const url = Astro.request.url;
import { ClipboardCopy } from "@astro-github-elements/clipboard-copy";
import { getEntry } from "astro:content";
const entry = await getEntry("blog", post.slug);
---

<html lang="en">
  <head>
    <Head title="🦊 Anton Bashirov | Blog" />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0"
    />
  </head>
  <body>
    <Navigation page="blog" />
    <div class="divider"></div>

    <div class="prose max-w-none w-2/3 m-auto">
      <ClipboardCopy value={url}>
        <div class="flex flex-row gap-2">
          <h1>
            {entry.data.title}
          </h1>
          <span class="material-symbols-outlined">content_copy</span>
        </div>
      </ClipboardCopy>
      <Content client:load />
    </div>
  </body>
</html>
