---
import { getCollection, getEntry } from "astro:content";
import Head from "../layouts/Head.astro";
import Navigation from "../layouts/Navigation.astro";
import { Article } from "../components/Blog";
export const articles = await getCollection("blog");
---

<html lang="en">
  <head>
    <Head title="🦊 Anton Bashirov | Blog" />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0"
    />
  </head>
  <body>
    <Navigation page="blog" />
    <div class="flex place-items-center">
      <div class="flex place-items-center flex-1 px-8 py-4">
        <span
          class="material-symbols-outlined text-3xl drop-shadow-glow text-light-blue-300"
          >rss_feed</span
        >
        <p class="text-3xl font-bold px-4">My own thoughts and theories</p>
      </div>
    </div>
    <div class="divider"></div>
    <div class="grid grid-cols-3 gap-4 p-4">
      {
        articles.map((post) => (
          <Article
            title={post.data.title}
            description={post.data.description}
            reference={post.slug}
          />
        ))
      }
    </div>
  </body>
</html>
