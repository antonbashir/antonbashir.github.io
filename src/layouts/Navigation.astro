---
interface Props {
  page?: string;
}
const { page = "" } = Astro.props;
var activeButton = `btn btn-wide btn-ghost btn-active`;
var inactiveButton = `btn btn-wide btn-ghost`;
---

<div class="navbar pl-8 pr-8 pt-8">
  <div class="navbar-start">
    <div class="flex place-items-center place-content-center btn-lg">
      <a href="/"> 🦊</a>
    </div>
  </div>
  <div class="navbar-center hidden lg:flex gap-8">
    <a class={page == "path" ? activeButton : inactiveButton} href="/path/"
      >Path</a
    >
    <a
      class={page == "projects" ? activeButton : inactiveButton}
      href="/projects/">Projects</a
    >
    <a class={page == "blog" ? activeButton : inactiveButton} href="/blog/"
      >Blog</a
    >
    <a
      class={page == "contacts" ? activeButton : inactiveButton}
      href="/contacts/">Contacts</a
    >
  </div>
  <div class="navbar-end"></div>
</div>
